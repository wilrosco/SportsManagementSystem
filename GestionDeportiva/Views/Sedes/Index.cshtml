@model IEnumerable<GestionDeportiva.Models.Sede>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Sedes</h2>

<p>
    @Html.ActionLink("Crear nuevo registro", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.SedeNombre)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Deporte.DeporteNombre)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.SedeNombre)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Deporte.DeporteNombre)
        </td>
        <td>
            @Html.ActionLink("Editar", "Edit", new { id=item.SedeId }) |
            @Html.ActionLink("Detalles", "Details", new { id=item.SedeId }) |
            @Html.ActionLink("Borrar", "Delete", new { id=item.SedeId })
        </td>
    </tr>
}

</table>
